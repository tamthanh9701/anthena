{
  "name": "reverse-ds-pipeline",
  "version": "1.0.0",
  "description": "Backend for the Reverse Design System Pipeline — extracts design tokens and components from web applications",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "node src/db/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:nfr": "vitest run tests/nfr",
    "test:coverage": "vitest run --coverage",
    "cleanup": "node src/store/retention-sweeper.js"
  },
  "keywords": [
    "design-system",
    "reverse-engineering",
    "figma",
    "playwright"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "playwright": "^1.52.0",
    "sharp": "^0.34.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
