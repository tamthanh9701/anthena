# Reverse Design System Pipeline — Configuration
PORT=3000
API_TOKEN=change-me-to-a-secure-token
LOG_LEVEL=info
NODE_ENV=development

# Target Application
TARGET_URL=https://staging.example.com

# Route List (JSON array of absolute URLs, 5-10 entries)
ROUTE_LIST=["https://staging.example.com/dashboard","https://staging.example.com/reports","https://staging.example.com/settings/profile","https://staging.example.com/admin/users","https://staging.example.com/admin/roles"]

# Role Map (JSON object mapping role name -> route list subset)
ROLE_MAP={"admin":["https://staging.example.com/dashboard","https://staging.example.com/reports","https://staging.example.com/settings/profile","https://staging.example.com/admin/users","https://staging.example.com/admin/roles"],"user":["https://staging.example.com/dashboard","https://staging.example.com/reports","https://staging.example.com/settings/profile"]}

# Credentials (per role)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin-password
USER_USERNAME=user
USER_PASSWORD=user-password
#VIEWER_USERNAME=viewer
#VIEWER_PASSWORD=viewer-password

# Retention
MAX_RUNS_PER_ROUTE=5
FAILED_RUN_RETENTION_DAYS=7
JSON_RETENTION_DAYS=0

# Crawler
RETRY_COUNT=3
ROUTE_TIMEOUT_MS=30000
QUEUE_POLL_INTERVAL_MS=5000
PLAYWRIGHT_HEADLESS=true
MAX_CONCURRENT_BROWSERS=2

# Phase 5 — Figma (optional)
#FIGMA_ACCESS_TOKEN=
#FIGMA_FILE_KEY=

# Storage paths
STORAGE_PATH=./storage
DB_PATH=./data