# ============================================================
# Reverse Design System Pipeline — Environment Configuration
# ============================================================
# Copy this file to config/.env and fill in the values.
# NEVER commit the actual .env file to version control.
# ============================================================

# --- Target App Credentials ---
TARGET_URL=https://staging.app.company.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

USER_USERNAME=user
USER_PASSWORD=change_me

# Viewer role (optional)
# VIEWER_USERNAME=viewer
# VIEWER_PASSWORD=change_me

# --- Pipeline API Auth ---
# API_TOKEN is used to authenticate API requests from the Web UI.
# Generate a strong random token: openssl rand -hex 32
API_TOKEN=change_me_generate_a_random_token_here

# --- Route Configuration ---
# JSON array of routes to crawl (relative to TARGET_URL)
ROUTE_LIST=["/dashboard","/orders","/orders/create","/users","/users/123","/products","/settings","/reports"]

# JSON object mapping roles to their accessible routes
ROLE_MAP={"admin":["/dashboard","/orders","/users","/settings","/reports"],"user":["/dashboard","/orders","/products"]}

# --- Pipeline Settings ---
LOG_LEVEL=info
PORT=3000
MAX_RUNS_PER_ROUTE=5
FAILED_RUN_RETENTION_DAYS=7
ROUTE_TIMEOUT=30000
RETRY_COUNT=3

# --- Crawler Kill Switch ---
# Set to true to disable crawler (start-run returns 503)
# DISABLE_CRAWLER=false

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900

# --- Figma Integration (Phase 5+) ---
# FIGMA_ACCESS_TOKEN=
# FIGMA_FILE_KEY=

# --- Logging ---
# Docker log driver settings (applied in docker-compose.yml)
# LOG_JSON_MAX_SIZE=50m
# LOG_JSON_MAX_FILE=5