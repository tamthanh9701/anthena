# ============================================================
# Reverse Design System Pipeline — .gitignore
# ============================================================

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
config/.env
secrets/
*.key
*.pem
*.cert

# --- Dependencies ---
node_modules/
api/node_modules/
crawler/node_modules/
web-ui/node_modules/

# --- Build Outputs ---
dist/
api/dist/
crawler/dist/
web-ui/dist/
build/
*.tsbuildinfo

# --- Docker Volumes (runtime data) ---
volumes/
/data/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS Files ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- TypeScript ---
*.ts.map
*.js.map

# --- Temp ---
tmp/
temp/
*.tmp

# --- Docker ---
.docker/
docker-compose.override.yml